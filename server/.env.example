PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_THREAD_ID=

# JWT Secret — THAY BẰNG CHUỖI NGẪU NHIÊN DÀI, BÍ MẬT!
# Tạo ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=hzsa

# Gmail SMTP — dùng để gửi mã reset mật khẩu cho người dùng
# Bước 1: Bật 2FA cho tài khoản Google
# Bước 2: Tạo App Password tại: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
